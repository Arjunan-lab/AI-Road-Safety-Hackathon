# Google Gemini API key — get yours at https://aistudio.google.com/apikey
# If left empty, the triage endpoint will return mock data.
GEMINI_API_KEY=your_gemini_api_key_here

# Twilio Sandbox credentials — get yours at https://console.twilio.com/
# Required for Zero-Touch WhatsApp auto-dispatch on crash.
# Leave empty to fall back to wa.me deep-link method (manual send).
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=your_auth_token_here
# This is the Twilio Sandbox WhatsApp sender number (do NOT change format)
TWILIO_WHATSAPP_FROM=whatsapp:+14155238886
